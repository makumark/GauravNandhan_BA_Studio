generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enterprise: Organization (one per client company) ─────────────────────────
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("STARTER")   // STARTER | PROFESSIONAL | ENTERPRISE
  maxUsers  Int      @default(10)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   OrganizationMember[]
  projects  Project[]
  auditLogs AuditLog[]
  templates Template[]
  integrationConfigs IntegrationConfig[]
}

// ── Enterprise: Links Users to Organizations with a role ──────────────────────
model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("BA_ANALYST") // ADMIN | BA_LEAD | BA_ANALYST | PM | DEVELOPER | QA_VIEWER
  joinedAt       DateTime     @default(now())
  isActive       Boolean      @default(true) // For suspending access to this org

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

// ── Enterprise: Immutable audit log ───────────────────────────────────────────
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  userEmail      String
  action         String   // DOCUMENT_GENERATED | SESSION_SAVED | PDF_EXPORTED | USER_INVITED | LOGIN | USER_REMOVED | ROLE_CHANGED | PASSWORD_RESET | USER_SUSPENDED | USER_ACTIVATED
  resourceType   String?  // BRD | FRD | UML Diagrams | etc.
  resourceId     String?
  metadata       String?  // JSON string for extra context
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ── Core: User ─────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  projects    Project[]
  memberships OrganizationMember[]
  taskComments TaskComment[]
}

// ── Core: Project ──────────────────────────────────────────────────────────────
model Project {
  id             String        @id @default(cuid())
  title          String
  userId         String
  organizationId String?       // null for legacy solo users — non-destructive
  pmId           String?       // Assigned Project Manager

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("DRAFT") // DRAFT | READY_FOR_PM | NEEDS_REVISION | APPROVED
  pmFeedback String? // Feedback from PM when rejecting a project

  messages    Message[]
  documents   Document[]
  graphNodes  GraphNode[]
  graphEdges  GraphEdge[]
  scopeSnapshots ScopeSnapshot[]
  sprints     Sprint[]
  tasks       Task[]
}

// ── Core: Message ──────────────────────────────────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())
}

// ── Core: Document ─────────────────────────────────────────────────────────────
model Document {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // "BRD", "FRD", "PRD", etc.
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions    DocumentVersion[]
  suggestions DocumentSuggestion[]
  traceabilityLinks TraceabilityLink[]
}

// ── Semantic Graph: Knowledge Graph Nodes ────────────────────────────────────
// Stores every artifact (Requirement, Screen, API, Test Case, Document)
// as a named node scoped to a project. nodeId matches IDs from AI snapshots
// (e.g. "REQ-1", "SCR-04", "API-02", "TC-12", "BRD").
model GraphNode {
  id        String   @id @default(cuid())
  projectId String
  nodeId    String   // e.g. "REQ-1", "SCR-04", "API-02", "TC-12"
  nodeType  String   // "REQUIREMENT" | "SCREEN" | "API" | "TEST_CASE" | "DOCUMENT" | "EPIC" | "FEATURE"
  label     String   // Human-readable name
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outEdges  GraphEdge[] @relation("EdgeFrom")
  inEdges   GraphEdge[] @relation("EdgeTo")
  traceabilityLinks TraceabilityLink[]

  @@unique([projectId, nodeId])
}

// ── Semantic Graph: Directed Edges between Nodes ──────────────────────────────
// Each edge captures a typed relationship between two graph nodes.
// relationship values: "CONTAINS" | "RENDERS_ON" | "CALLS" | "VERIFIED_BY" | "DOCUMENTED_IN"
model GraphEdge {
  id           String   @id @default(cuid())
  projectId    String
  fromNodeId   String   // references GraphNode.id (cuid)
  toNodeId     String   // references GraphNode.id (cuid)
  relationship String
  createdAt    DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromNode GraphNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   GraphNode @relation("EdgeTo",   fields: [toNodeId],   references: [id], onDelete: Cascade)

  @@unique([projectId, fromNodeId, toNodeId, relationship])
}

// ── Core: Document Version ──────────────────────────────────────────────────
model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  content    String   // The text or JSON content at this version
  createdAt  DateTime @default(now())
  createdBy  String   // User ID who created this version

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// ── Core: AI Suggestion (Tracked Changes) ───────────────────────────────────
model DocumentSuggestion {
  id             String   @id @default(cuid())
  documentId     String
  originalText   String
  suggestedText  String
  status         String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt      DateTime @default(now())

  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// ── Core: Template ────────────────────────────────────────────────────────────
model Template {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  content        String   // Markdown or Text template with placeholders
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ── Scope Tracking: Snapshot of requirements per chat round ─────────────────
// Persists requirement counts across browser sessions so the Scope-Creep Index
// can compare baseline (round 1) vs latest (round N) for any number of users.
model ScopeSnapshot {
  id        String   @id @default(cuid())
  projectId String
  round     Int      // Chat round number (1, 2, 3...)
  reqCount  Int      // Number of confirmed requirements at this round
  snapshot  String   // Full JSON array of { id, text, status } for detail view
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, round])
}

// ── Advanced Project Management: Sprints ───────────────────────────────────────
model Sprint {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("PLANNED") // PLANNED | ACTIVE | COMPLETED

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Advanced Project Management: Tasks ─────────────────────────────────────────
model Task {
  id          String   @id @default(cuid())
  sprintId    String?
  projectId   String
  title       String
  description String?
  status      String   @default("TODO") // TODO | IN_PROGRESS | REVIEW | DONE | NEEDS_REVISION
  assigneeId  String?  // References OrganizationMember.id or User.id
  jiraIssueId String?
  externalId  String?  // For other integrations
  storyPoints Int?     // Agile story points
  priority    String   @default("MEDIUM") // HIGH | MEDIUM | LOW
  
  sprint      Sprint?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  traceabilityLinks TraceabilityLink[]
  comments          TaskComment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Advanced Project Management: Task Comments (PM Feedback) ───────────────────
model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String   // The PM/User who left the feedback
  content   String   // The feedback text
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Advanced Project Management: Traceability Links ────────────────────────────
model TraceabilityLink {
  id          String   @id @default(cuid())
  taskId      String
  documentId  String?  // Link to a full document
  graphNodeId String?  // Link to a specific node (Wireframe, UML, FRD req)
  
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  document    Document?  @relation(fields: [documentId], references: [id], onDelete: SetNull)
  graphNode   GraphNode? @relation(fields: [graphNodeId], references: [id], onDelete: SetNull)
}

// ── Advanced Project Management: Integrations ──────────────────────────────────
model IntegrationConfig {
  id             String   @id @default(cuid())
  organizationId String
  provider       String   // JIRA | AZURE_DEVOPS | ASANA
  webhookSecret  String?
  configData     String?  // JSON string
  
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
}

